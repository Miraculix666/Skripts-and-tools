## `Invoke-SCCMClientAppMgmt` – Der Haupt-Cmdlet

```powershell
function Invoke-SCCMClientAppMgmt {
    [CmdletBinding(DefaultParameterSetName='StatusAndPrompt')]
    param(
        [Parameter(Mandatory=$false,
                   HelpMessage="Specify the computer name to manage. Defaults to local computer.")]
        [string]$ComputerName = $env:COMPUTERNAME,

        [Parameter(ParameterSetName='InstallAll', Mandatory=$true,
                   HelpMessage="Automatically install all identified pending SCCM applications.")]
        [switch]$InstallAll,

        [Parameter(ParameterSetName='StatusAndPrompt', Mandatory=$true,
                   HelpMessage="Prompt for individual installation of pending SCCM applications.")]
        [switch]$PromptInstall,

        [Parameter(Mandatory=$false,
                   HelpMessage="Trigger an immediate Machine Policy Retrieval & Evaluation Cycle on the client.")]
        [switch]$RefreshPolicy,

        [Parameter(Mandatory=$false,
                   HelpMessage="Show differences between server-intended packages (client view) and installed status.")]
        [switch]$ShowDifferences
    )

    # --- Interaktive Parameterabfrage, falls nicht gesetzt ---
    if (-not $PSBoundParameters.ContainsKey('ComputerName')) {
        $ComputerName = Read-Host "Enter the computer name (default: $env:COMPUTERNAME)"
        if ([string]::IsNullOrWhiteSpace($ComputerName)) { $ComputerName = $env:COMPUTERNAME }
    }

    # Wenn weder InstallAll noch PromptInstall gesetzt ist, setze PromptInstall als Standardverhalten
    if (-not $InstallAll -and -not $PSBoundParameters.ContainsKey('PromptInstall')) {
        $PromptInstall = $true
    }
    # --- Ende der interaktiven Parameterabfrage ---

    Write-Host "`n--- Starting SCCM Client Application Management for ${ComputerName} ---" -ForegroundColor Green

    # Show potential server-client differences before policy refresh, if requested
    if ($ShowDifferences) {
        Write-Host "`n--- Displaying potential Server-Client differences (client's view before refresh) ---" -ForegroundColor Yellow
        Write-Host "Note: This view is based on the client's last known state, not live server data."
        $currentSCCMDetails = Get-SCCMAppStatus -ComputerName $ComputerName

        if ($currentSCCMDetails) {
            $serverDrivenPending = $currentSCCMDetails | Where-Object {
                $_.IsPendingAction -and # App requires action (not installed, not N/A, not Unknown)
                $_.Status -ne "NotApplicable" # Exclude explicit "Not Applicable"
            }
            if ($serverDrivenPending.Count -gt 0) {
                Write-Host "Following applications are currently marked as 'Pending' or 'Available' by the server (according to client):" -ForegroundColor Red
                $serverDrivenPending | Format-Table Name, Status, IsMachineTarget, UserInstallable, Deadline -AutoSize
            } else {
                Write-Host "No applications currently marked as 'Pending' or 'Available' by the server." -ForegroundColor Green
            }
        } else {
            Write-Warning "Could not retrieve current SCCM client details to show differences."
        }
        Write-Host "--- End of Difference Display ---" -ForegroundColor Green
    }

    # Trigger policy refresh, if requested
    if ($RefreshPolicy) {
        Invoke-SCCMPolicyRefresh -ComputerName $ComputerName
        Write-Host "Please wait a moment for the client to process the new policy..." -ForegroundColor DarkYellow
        Start-Sleep -Seconds 30
    }

    # Retrieve current data after potential refresh
    $installedApps = Get-InstalledApp -ComputerName $ComputerName
    $sccmApps = Get-SCCMAppStatus -ComputerName $ComputerName

    if (-not $installedApps) {
        Write-Warning "Could not retrieve installed software on ${ComputerName}. Skipping comparison."
        return
    }
    if (-not $sccmApps) {
        Write-Warning "Could not retrieve SCCM application details on ${ComputerName}. Skipping comparison."
        return
    }

    # Normalize names for comparison
    $installedNormalized = $installedApps | Select-Object @{N='NName'; E={Convert-AppNameToNormalized $_.DisplayName}}, DisplayName
    $sccmNormalized = $sccmApps | Select-Object @{N='NName'; E={Convert-AppNameToNormalized $_.Name}}, *

    Write-Host "`n--- Pending/Relevant SCCM Applications (client's view) ---" -ForegroundColor Yellow
    Write-Host "This includes apps not installed or needing an update/action." -ForegroundColor Yellow
    $allRelevantSCCMApps = @()

    foreach ($sccmApp in $sccmNormalized) {
        # Check if the app is either "truly pending" (Status != Installed, N/A, Unknown)
        # OR an update that is not yet installed.
        if ($sccmApp.IsPendingAction -or $sccmApp.IsUpdatePending) {
            $allRelevantSCCMApps += $sccmApp
        }
    }

    if ($allRelevantSCCMApps.Count -gt 0) {
        Write-Host "Following SCCM applications require attention (installations/updates):" -ForegroundColor Red
        $allRelevantSCCMApps | Format-Table Name, Status, IsUpdatePending, IsMachineTarget, UserInstallable, Deadline, EstimatedTime -AutoSize

        # Installation options
        if ($InstallAll) {
            Write-Host "`nAutomatically installing all pending/relevant applications..." -ForegroundColor Magenta
            foreach ($appToInstall in $allRelevantSCCMApps) {
                if ($appToInstall.AppId -and $appToInstall.PolicyId) {
                    Write-Host "Starting installation for: $($appToInstall.Name)" -ForegroundColor DarkYellow
                    Invoke-SCCMAppInstall -ComputerName $ComputerName -AppId $appToInstall.AppId -PolicyId $appToInstall.PolicyId
                } else {
                    Write-Warning "Application '${appToInstall.Name}' has no valid ID/PolicyId for installation."
                }
            }
        } elseif ($PromptInstall) {
            Write-Host "`nPrompting for individual pending/relevant applications..." -ForegroundColor Magenta
            foreach ($appToInstall in $allRelevantSCCMApps) {
                if ($appToInstall.AppId -and $appToInstall.PolicyId) {
                    $confirm = Read-Host "Install '${appToInstall.Name}' (Status: $($appToInstall.Status), Update Pending: $($appToInstall.IsUpdatePending))? (Y/N)"
                    if ($confirm -eq "Y") {
                        Write-Host "Starting installation for: $($appToInstall.Name)" -ForegroundColor DarkYellow
                        Invoke-SCCMAppInstall -ComputerName $ComputerName -AppId $appToInstall.AppId -PolicyId $appToInstall.PolicyId
                    } else {
                        Write-Host "Installation of '${appToInstall.Name}' skipped." -ForegroundColor Yellow
                    }
                } else {
                    Write-Warning "Application '${appToInstall.Name}' has no valid ID/PolicyId for installation."
                }
            }
        }
    } else {
        Write-Host "No pending/relevant installations or updates found in SCCM." -ForegroundColor Green
    }
    
    Write-Host "`n--- Detailed list of all SCCM applications and their status ---" -ForegroundColor DarkCyan
    $sccmApps | Format-Table Name, Status, IsInstalled, IsUpdate, IsUpdatePending, IsPendingAction, IsMachineTarget, UserInstallable, InstallSource, Deadline, EstimatedTime, LastUpdated, ExecutionLevel -AutoSize

    Write-Host "`n--- End of SCCM Client Application Management for ${ComputerName} ---" -ForegroundColor Green
}

