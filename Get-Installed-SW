#
# Funktion: Get-InstalledSoftware
# Beschreibung: Ruft die auf einem Computer installierte Software aus dem Uninstall-Register ab.
# Parameter:
#   -ComputerName: Der Name des Computers, von dem die Softwareinformationen abgerufen werden sollen.
#                  Standardwert ist der lokale Computer.
# Rückgabe: Eine Liste von Objekten mit DisplayName, DisplayVersion, Publisher und InstallDate.
#
function Get-InstalledSoftware {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory=$false)]
        [string]$ComputerName = $env:COMPUTERNAME
    )

    Write-Host "Abfrage der installierten Software auf ${ComputerName}..." -ForegroundColor Cyan

    $regPaths = @(
        "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\*",
        "HKLM:\SOFTWARE\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall\*"
    )
    $installedSoftware = @()

    try {
        # Remote-Ausführung für jeden Registry-Pfad
        foreach ($path in $regPaths) {
            $softwareEntries = Invoke-Command -ComputerName $ComputerName -ScriptBlock {
                # In einem Remote-ScriptBlock muss $using:path verwendet werden, um auf lokale Variablen zuzugreifen
                Get-ItemProperty -Path $using:path -ErrorAction SilentlyContinue |
                    Where-Object { $_.DisplayName -ne $null } |
                    Select-Object DisplayName, DisplayVersion, Publisher, InstallDate, InstallLocation
            }
            if ($softwareEntries) {
                $installedSoftware += $softwareEntries
            }
        }
    }
    catch {
        Write-Error "Fehler beim Abrufen der installierten Software auf ${ComputerName}: ${_.Exception.Message}"
        return $null
    }

    # Sortieren und Duplikate entfernen (manchmal doppelte Einträge bei 32/64-Bit-Programmen)
    return $installedSoftware | Sort-Object DisplayName -Unique
}

#
# Funktion: Get-SCCMApplicationDetails
# Beschreibung: Ruft detaillierte Informationen zu SCCM-Anwendungen ab und prüft den Status.
# Parameter:
#   -ComputerName: Der Name des Computers, von dem die SCCM-Informationen abgerufen werden sollen.
#                  Standardwert ist der lokale Computer.
# Rückgabe: Eine Liste von Objekten mit ApplicationName, InstallState, IsMachineTarget,
#          UserInstallAvailable, IsUpdate, IsInstalled, InstallStateName und weiteren Details.
#
function Get-SCCMApplicationDetails {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory=$false)]
        [string]$ComputerName = $env:COMPUTERNAME
    )

    Write-Host "Abfrage detaillierter SCCM-Anwendungsdetails auf ${ComputerName}..." -ForegroundColor Cyan

    $sccmApplications = @()

    try {
        # Definition der InstallState-Werte für bessere Lesbarkeit
        $installStates = @{
            0 = "Unknown"
            1 = "Installed"
            2 = "Available" # Available (not installed, can be installed)
            3 = "Downloading"
            4 = "Pending"
            5 = "Installing"
            6 = "Failed"
            7 = "Superseded"
            8 = "NoContent"
            9 = "NotApplicable"
            10 = "PendingRestart"
            11 = "PendingInstall"
            12 = "PendingUserLogoff"
            13 = "DownloadingContent"
            14 = "WaitingForContent"
            15 = "WaitingForServiceWindow"
            16 = "WaitingForDependencies"
            17 = "WaitingForRestart"
            18 = "WaitingForUserLogon"
            19 = "WaitingForSystemReset"
            20 = "WaitingForConfiguration"
            21 = "WaitingForCompletion"
            22 = "WaitingForRetry"
        }

        # Abfrage der CCM_Application Klasse im Namespace root\ccm\ClientSDK
        # Wir müssen Invoke-Command verwenden, um auf dem Remote-Client die WMI-Informationen abzurufen.
        $rawSCCMApps = Invoke-Command -ComputerName $ComputerName -ScriptBlock {
            Get-WmiObject -Namespace "root\ccm\ClientSDK" -Class CCM_Application -ErrorAction Stop |
                Select-Object Name, InstallState, IsMachineTarget, UserInstallAvailable, IsUpdate, Id, PolicyID,
                            InstallSource, LastUpdateTime, EstimatedInstallTime, Deadline, RequestedExecutionLevel # Weitere relevante Parameter
        }

        foreach ($app in $rawSCCMApps) {
            # Ist die Software bereits installiert (InstallState = 1)?
            $isInstalled = ($app.InstallState -eq 1)

            # Ist ein Update ausstehend?
            # Wir definieren "UpdatePending" als: Die App ist als Update markiert UND ist NICHT installiert (InstallState != 1).
            # Dies ist eine starke Indikation für ein ausstehendes Update.
            $isUpdatePending = ($app.IsUpdate -and -not $isInstalled)

            # Ist die Anwendung generell als "ausstehend" für eine Aktion markiert (nicht installiert, aber relevant)?
            # InstallState 2 (Available), 4 (Pending), 10 (PendingRestart), 11 (PendingInstall) sind gute Kandidaten.
            # Aber wir nehmen hier alle Zustände, die nicht "Installed" sind, außer "NotApplicable" und "Unknown".
            $isTrulyPending = ($app.InstallState -ne 1 -and $app.InstallState -ne 0 -and $app.InstallState -ne 9)

            [PSCustomObject]@{
                ApplicationName = $app.Name
                InstallState = $app.InstallState
                InstallStateName = $installStates[$app.InstallState]
                IsMachineTarget = $app.IsMachineTarget # True, wenn die Anwendung für das Gerät und nicht den Benutzer ist
                UserInstallAvailable = $app.UserInstallAvailable # True, wenn der User sie im Software Center sehen und installieren kann
                IsUpdate = $app.IsUpdate # True, wenn dies ein Update ist (Indikator, kein Status)
                IsInstalled = $isInstalled # True, wenn InstallState = 1 ist
                IsUpdatePending = $isUpdatePending # Unser Indikator, ob ein Update aussteht
                IsTrulyPending = $isTrulyPending # Unser Indikator, ob *irgendeine* ausstehende Aktion vorliegt

                # Details für die Installation
                ApplicationID = $app.Id
                ApplicationPolicyID = $app.PolicyID

                # Weitere relevante Parameter aus dem SCCM Client
                InstallSource = $app.InstallSource # Woher die Installation kommt
                LastUpdateTime = if ($app.LastUpdateTime) { [DateTime]::ParseExact($app.LastUpdateTime.Substring(0,14), "yyyyMMddHHmmss", $null) } else { $null } # Datum des letzten Updates
                EstimatedInstallTime = $app.EstimatedInstallTime # Geschätzte Installationszeit in Minuten
                Deadline = if ($app.Deadline) { [DateTime]::ParseExact($app.Deadline.Substring(0,14), "yyyyMMddHHmmss", $null) } else { $null } # Deadline der Installation
                RequestedExecutionLevel = $app.RequestedExecutionLevel # RequiredExecutionLevel
            }
        }
    }
    catch {
        Write-Error "Fehler beim Abrufen der SCCM-Anwendungsdetails auf ${ComputerName}: ${_.Exception.Message}"
        Write-Error "Stellen Sie sicher, dass der SCCM Client auf diesem System installiert ist und WinRM aktiviert ist."
        return $null
    }

    return $sccmApplications | Sort-Object ApplicationName -Unique
}

#
# Funktion: Request-SCCMApplicationInstallation
# Beschreibung: Löst die Installation einer SCCM-Anwendung aus.
# Parameter:
#   -ComputerName: Der Name des Computers, auf dem die Installation ausgelöst werden soll.
#   -ApplicationID: Die ID der Anwendung, die installiert werden soll.
#   -ApplicationPolicyID: Die PolicyID der Anwendung, die installiert werden soll.
#
function Request-SCCMApplicationInstallation {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory=$true)]
        [string]$ComputerName,
        [Parameter(Mandatory=$true)]
        [string]$ApplicationID,
        [Parameter(Mandatory=$true)]
        [string]$ApplicationPolicyID
    )

    Write-Host "Versuche, Installation für Anwendung '${ApplicationID}' auf ${ComputerName} auszulösen..." -ForegroundColor Yellow

    try {
        Invoke-Command -ComputerName $ComputerName -ScriptBlock {
            param($appId, $policyId)
            $SMSClient = New-Object -ComObject 'Microsoft.SMS.Client'
            $ApplicationManagement = $SMSClient.GetClientSettings().GetApplicationManagementInterface()
            
            if ($ApplicationManagement) {
                # Install-Methode aufrufen. Dies ist der "Install Application" Button im Software Center
                # Bei manchen Anwendungen kann es notwendig sein, zusätzlich eine Parameterhash zu übergeben,
                # aber die Standardmethode ohne Parameter ist oft ausreichend.
                $ApplicationManagement.InstallApplication($appId, $policyId)
                Write-Host "Installation von Anwendung '${appId}' erfolgreich ausgelöst." -ForegroundColor Green
            } else {
                Write-Error "Konnte Application Management Interface nicht abrufen. Installation nicht ausgelöst."
            }
        } -ArgumentList $ApplicationID, $ApplicationPolicyID
    }
    catch {
        Write-Error "Fehler beim Auslösen der Installation auf ${ComputerName}: ${_.Exception.Message}"
        Write-Error "Stellen Sie sicher, dass der SCCM Client läuft und Berechtigungen vorhanden sind."
    }
}

#
# Funktion: Request-SCCMPolicyRefresh
# Beschreibung: Initiiert einen sofortigen Abruf der Maschinenrichtlinie (Machine Policy Retrieval & Evaluation Cycle) im SCCM-Client.
# Parameter:
#   -ComputerName: Der Name des Computers, auf dem der Richtlinien-Abruf ausgelöst werden soll.
#
function Request-SCCMPolicyRefresh {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory=$true)]
        [string]$ComputerName
    )

    Write-Host "Initiere SCCM Maschinenrichtlinien-Abruf auf ${ComputerName}..." -ForegroundColor Yellow

    try {
        Invoke-Command -ComputerName $ComputerName -ScriptBlock {
            $SMSClient = New-Object -ComObject 'Microsoft.SMS.Client'
            $SMSClient.TriggerSchedule("{00000000-0000-0000-0000-000000000001}") # Machine Policy Retrieval & Evaluation Cycle
            Write-Host "Maschinenrichtlinien-Abruf erfolgreich ausgelöst." -ForegroundColor Green
        }
    }
    catch {
        Write-Error "Fehler beim Auslösen des Maschinenrichtlinien-Abrufs auf ${ComputerName}: ${_.Exception.Message}"
        Write-Error "Stellen Sie sicher, dass der SCCM Client läuft und Berechtigungen vorhanden sind."
    }
}

#
# Funktion: Normalize-SoftwareName
# Beschreibung: Versucht, einen Softwarenamen für den Vergleich zu normalisieren.
#              Entfernt häufige Versionsmuster, "Microsoft ", "Adobe ", etc.
# Parameter:
#   -Name: Der zu normalisierende Softwarename.
# Rückgabe: Der normalisierte Name.
#
function Normalize-SoftwareName {
    param(
        [string]$Name
    )
    $normalizedName = $Name.ToLower().Trim()

    # Entferne bekannte Präfixe und Suffixe
    $normalizedName = $normalizedName -replace "(?i)^(microsoft|adobe|google|mozilla|ibm|cisco) " # Präfixe
    $normalizedName = $normalizedName -replace "(?i) (x64|x86|64-bit|32-bit|arm)$" # Architektur
    $normalizedName = $normalizedName -replace "(?i) v?\d+(\.\d+){0,4}(\.\d+)?(-[a-z0-9]+)?( \d+)?( \(.*\))?$" # Versionsnummern (v1.2.3, 1.2.3 (build), -beta, etc.)
    $normalizedName = $normalizedName -replace "(?i) (setup|installer|client|agent|runtime)$" # " Setup", " Installer" etc.
    $normalizedName = $normalizedName -replace "(?i) (freeware|shareware|community edition|professional|enterprise|standard|plus)$" # Editionen
    $normalizedName = $normalizedName -replace "[^a-z0-9 ]", "" # Alle nicht-alphanumerischen Zeichen außer Leerzeichen entfernen
    $normalizedName = $normalizedName -replace " +", " " # Mehrere Leerzeichen durch eines ersetzen
    $normalizedName = $normalizedName.Trim()

    return $normalizedName
}


#
# Hauptteil des Skripts: Abruf, Vergleich und optional Installation/Synchronisation
#
function Compare-AndManage-SCCMSoftwareStatus {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory=$true)]
        [string]$ComputerName,
        [switch]$InstallAllPending, # Schalter, um alle ausstehenden automatisch zu installieren
        [switch]$PromptForIndividualInstallation, # Schalter, um für jede ausstehende Installation zu fragen
        [switch]$InitiatePolicyRefresh, # Schalter, um den Maschinenrichtlinien-Abruf auszulösen
        [switch]$ShowServerClientDifferences # Schalter, um potenzielle Server-Client-Differenzen anzuzeigen
    )

    Write-Host "`n--- Start des erweiterten SCCM-Software-Managements für ${ComputerName} ---" -ForegroundColor Green

    # Zeige potenzielle Server-Client-Differenzen vor Synchronisation, falls angefordert
    if ($ShowServerClientDifferences) {
        Write-Host "`n--- Anzeige potenzieller Server-Client-Differenzen vor Synchronisation ---" -ForegroundColor Yellow
        Write-Host "Hinweis: Diese Daten basieren auf dem letzten bekannten Zustand des Clients."
        # Um echte Server-Daten abzugleichen, bräuchte man Zugriff auf die SCCM-Datenbank/APIs auf dem Server.
        # Hier zeigen wir stattdessen, welche Apps der Client als 'Available' oder 'Pending' hat,
        # die vom Server bereitgestellt wurden, aber noch nicht installiert sind.
        # Dies ist die beste "Vorab-Sicht" ohne Serverzugriff.
        $currentSCCMDetails = Get-SCCMApplicationDetails -ComputerName $ComputerName

        if ($currentSCCMDetails) {
            $serverDrivenPending = $currentSCCMDetails | Where-Object { 
                $_.IsTrulyPending -and # Ist nicht installiert, aber relevant
                $_.InstallState -ne 9 # Ist nicht "NotApplicable"
            }
            if ($serverDrivenPending.Count -gt 0) {
                Write-Host "Folgende Anwendungen sind vom Server als 'Ausstehend' oder 'Verfügbar' vorgesehen (laut Client-Status):" -ForegroundColor Red
                $serverDrivenPending | Format-Table ApplicationName, InstallStateName, IsMachineTarget, UserInstallAvailable, Deadline -AutoSize
            } else {
                Write-Host "Aktuell keine Anwendungen im SCCM-Client als 'Ausstehend' oder 'Verfügbar' gelistet." -ForegroundColor Green
            }
        } else {
            Write-Warning "Konnte keine aktuellen SCCM-Client-Details abrufen, um Differenzen anzuzeigen."
        }
        Write-Host "--- Ende der Differenzanzeige ---" -ForegroundColor Green
    }

    # Richtlinien-Abruf initiieren, falls angefordert
    if ($InitiatePolicyRefresh) {
        Request-SCCMPolicyRefresh -ComputerName $ComputerName
        Write-Host "Bitte warten Sie einen Moment, bis der Client die neue Richtlinie verarbeitet hat..." -ForegroundColor DarkYellow
        Start-Sleep -Seconds 30 # Gib dem Client etwas Zeit, die Richtlinie zu verarbeiten
    }

    # Jetzt die aktuellen Daten abrufen
    $installedSoftware = Get-InstalledSoftware -ComputerName $ComputerName
    $sccmApplications = Get-SCCMApplicationDetails -ComputerName $ComputerName

    if (-not $installedSoftware) {
        Write-Warning "Konnte keine installierte Software auf ${ComputerName} abrufen. Überspringe den Vergleich."
        return
    }
    if (-not $sccmApplications) {
        Write-Warning "Konnte keine SCCM-Anwendungsdetails auf ${ComputerName} abrufen. Überspringe den Vergleich."
        return
    }

    # Normalisierte Namen für den Vergleich
    $installedNormalizedNames = $installedSoftware | Select-Object @{Name='NormalizedName'; Expression={Normalize-SoftwareName $_.DisplayName}}, DisplayName
    $sccmNormalizedNames = $sccmApplications | Select-Object @{Name='NormalizedName'; Expression={Normalize-SoftwareName $_.ApplicationName}}, * # * für alle Eigenschaften


    Write-Host "`n--- Ausstehende/Relevante SCCM-Anwendungen (laut Client-Status) ---" -ForegroundColor Yellow
    Write-Host "Dies beinhaltet Apps, die nicht 'Installed' sind oder ein Update benötigen." -ForegroundColor Yellow
    $allRelevantSCCMApps = @()

    foreach ($sccmApp in $sccmNormalizedNames) {
        # Ist die App entweder "wirklich ausstehend" (InstallState != Installed)
        # ODER ein Update und noch nicht installiert?
        if ($sccmApp.IsTrulyPending -or $sccmApp.IsUpdatePending) {
            $allRelevantSCCMApps += $sccmApp
        }
    }

    if ($allRelevantSCCMApps.Count -gt 0) {
        Write-Host "Folgende SCCM-Anwendungen benötigen Aufmerksamkeit (Installationen/Updates):" -ForegroundColor Red
        $allRelevantSCCMApps | Format-Table ApplicationName, InstallStateName, IsUpdatePending, IsMachineTarget, UserInstallAvailable, Deadline -AutoSize

        # Installationsoptionen
        if ($InstallAllPending) {
            Write-Host "`nInstalliere alle ausstehenden/relevanten Anwendungen automatisch..." -ForegroundColor Magenta
            foreach ($appToInstall in $allRelevantSCCMApps) {
                if ($appToInstall.ApplicationID -and $appToInstall.ApplicationPolicyID) {
                    Write-Host "Starte Installation für: $($appToInstall.ApplicationName)" -ForegroundColor DarkYellow
                    Request-SCCMApplicationInstallation -ComputerName $ComputerName -ApplicationID $appToInstall.ApplicationID -ApplicationPolicyID $appToInstall.ApplicationPolicyID
                } else {
                    Write-Warning "Anwendung '${appToInstall.ApplicationName}' hat keine gültige ID/PolicyID für die Installation."
                }
            }
        } elseif ($PromptForIndividualInstallation) {
            Write-Host "`nInstalliere ausstehende/relevante Anwendungen einzeln (Aufforderung für jede)..." -ForegroundColor Magenta
            foreach ($appToInstall in $allRelevantSCCMApps) {
                if ($appToInstall.ApplicationID -and $appToInstall.ApplicationPolicyID) {
                    $confirm = Read-Host "Möchten Sie '${appToInstall.ApplicationName}' (Status: $($appToInstall.InstallStateName), Update ausstehend: $($appToInstall.IsUpdatePending)) installieren? (J/N)"
                    if ($confirm -eq "J") {
                        Write-Host "Starte Installation für: $($appToInstall.ApplicationName)" -ForegroundColor DarkYellow
                        Request-SCCMApplicationInstallation -ComputerName $ComputerName -ApplicationID $appToInstall.ApplicationID -ApplicationPolicyID $appToInstall.ApplicationPolicyID
                    } else {
                        Write-Host "Installation von '${appToInstall.ApplicationName}' übersprungen." -ForegroundColor Yellow
                    }
                } else {
                    Write-Warning "Anwendung '${appToInstall.ApplicationName}' hat keine gültige ID/PolicyID für die Installation."
                }
            }
        } else {
            Write-Host "`nUm die ausstehende Software zu installieren, führe das Skript mit -InstallAllPending oder -PromptForIndividualInstallation aus." -ForegroundColor Green
        }

    } else {
        Write-Host "Keine ausstehenden/relevanten Installationen oder Updates im SCCM gefunden." -ForegroundColor Green
    }
    
    Write-Host "`n--- Detaillierte Liste aller SCCM-Anwendungen und ihres Status ---" -ForegroundColor DarkCyan
    $sccmApplications | Format-Table ApplicationName, InstallStateName, IsInstalled, IsUpdate, IsUpdatePending, IsTrulyPending, IsMachineTarget, UserInstallAvailable, InstallSource, Deadline -AutoSize

    Write-Host "`n--- Ende des SCCM-Software-Managements für ${ComputerName} ---" -ForegroundColor Green
}

# --- Beispielaufrufe ---

# Für einen Remote-PC mit manuellem Nachfragen bei ausstehenden/relevanten Installationen/Updates:
# $remotePC = "L26PBZD70080021"
# Compare-AndManage-SCCMSoftwareStatus -ComputerName $remotePC -PromptForIndividualInstallation

# Für einen Remote-PC, um alle ausstehenden/relevanten Installationen automatisch zu triggern:
# $remotePC = "L26PBZD70080021"
# Compare-AndManage-SCCMSoftwareStatus -ComputerName $remotePC -InstallAllPending

# Nur zur