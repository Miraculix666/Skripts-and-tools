#
# PowerShell Module: Invoke-SCCMClientAppMgmt.ps1
# Beschreibung: Verwaltet SCCM-Software auf Clients, listet installierte/ausstehende Apps,
#               und bietet Optionen zur Installation oder Richtlinien-Synchronisation.
#
# Konventionen:
# - Kürze und Prägnanz bei Funktions- und Parameternamen
# - Verwendung von Standard-Verben (Get, Invoke, Request)
# - Interaktive Abfragen für fehlende Parameter
# - Fokus auf Lesbarkeit und PowerShell-Best Practices
#

function Get-InstalledApp {
    [CmdletBinding()]
    param(
        [Parameter(Mandlandatory=$false)]
        [string]$ComputerName = $env:COMPUTERNAME
    )

    Write-Host "Checking installed software on ${ComputerName}..." -ForegroundColor Cyan

    $regPaths = @(
        "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\*",
        "HKLM:\SOFTWARE\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall\*"
    )
    $installedSoftware = @()

    try {
        foreach ($path in $regPaths) {
            $softwareEntries = Invoke-Command -ComputerName $ComputerName -ScriptBlock {
                Get-ItemProperty -Path $using:path -ErrorAction SilentlyContinue |
                    Where-Object { $_.DisplayName -ne $null } |
                    Select-Object DisplayName, DisplayVersion, Publisher, InstallDate, InstallLocation
            }
            if ($softwareEntries) {
                $installedSoftware += $softwareEntries
            }
        }
    }
    catch {
        Write-Error "Failed to retrieve installed software on ${ComputerName}: ${_.Exception.Message}"
        return $null
    }
    return $installedSoftware | Sort-Object DisplayName -Unique
}

function Get-SCCMAppStatus {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory=$false)]
        [string]$ComputerName = $env:COMPUTERNAME
    )

    Write-Host "Getting SCCM application status on ${ComputerName}..." -ForegroundColor Cyan

    $sccmApplications = @()
    try {
        $installStates = @{
            0 = "Unknown"; 1 = "Installed"; 2 = "Available"; 3 = "Downloading"; 4 = "Pending";
            5 = "Installing"; 6 = "Failed"; 7 = "Superseded"; 8 = "NoContent"; 9 = "NotApplicable";
            10 = "PendingRestart"; 11 = "PendingInstall"; 12 = "PendingUserLogoff"; 13 = "DownloadingContent";
            14 = "WaitingForContent"; 15 = "WaitingForServiceWindow"; 16 = "WaitingForDependencies";
            17 = "WaitingForRestart"; 18 = "WaitingForUserLogon"; 19 = "WaitingForSystemReset";
            20 = "WaitingForConfiguration"; 21 = "WaitingForCompletion"; 22 = "WaitingForRetry"
        }

        $rawSCCMApps = Invoke-Command -ComputerName $ComputerName -ScriptBlock {
            Get-WmiObject -Namespace "root\ccm\ClientSDK" -Class CCM_Application -ErrorAction Stop |
                Select-Object Name, InstallState, IsMachineTarget, UserInstallAvailable, IsUpdate, Id, PolicyID,
                            InstallSource, LastUpdateTime, EstimatedInstallTime, Deadline, RequestedExecutionLevel
        }

        foreach ($app in $rawSCCMApps) {
            $isInstalled = ($app.InstallState -eq 1)
            $isUpdatePending = ($app.IsUpdate -and -not $isInstalled)
            $isTrulyPending = ($app.InstallState -ne 1 -and $app.InstallState -ne 0 -and $app.InstallState -ne 9)

            [PSCustomObject]@{
                Name = $app.Name
                Status = $installStates[$app.InstallState]
                IsInstalled = $isInstalled
                IsUpdate = $app.IsUpdate
                IsUpdatePending = $isUpdatePending
                IsPendingAction = $isTrulyPending # Indicates any state requiring action (not installed, not N/A, not Unknown)
                IsMachineTarget = $app.IsMachineTarget
                UserInstallable = $app.UserInstallAvailable
                AppId = $app.Id
                PolicyId = $app.PolicyID
                InstallSource = $app.InstallSource
                LastUpdated = if ($app.LastUpdateTime) { [DateTime]::ParseExact($app.LastUpdateTime.Substring(0,14), "yyyyMMddHHmmss", $null) } else { $null }
                EstimatedTime = $app.EstimatedInstallTime
                Deadline = if ($app.Deadline) { [DateTime]::ParseExact($app.Deadline.Substring(0,14), "yyyyMMddHHmmss", $null) } else { $null }
                ExecutionLevel = $app.RequestedExecutionLevel
            }
        }
    }
    catch {
        Write-Error "Failed to get SCCM application status on ${ComputerName}: ${_.Exception.Message}"
        Write-Error "Ensure SCCM client is installed and WinRM is enabled."
        return $null
    }
    return $sccmApplications | Sort-Object Name -Unique
}

function Invoke-SCCMAppInstall {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory=$true)]
        [string]$ComputerName,
        [Parameter(Mandatory=$true)]
        [string]$AppId,
        [Parameter(Mandatory=$true)]
        [string]$PolicyId
    )

    Write-Host "Attempting to trigger installation for App ID '${AppId}' on ${ComputerName}..." -ForegroundColor Yellow

    try {
        Invoke-Command -ComputerName $ComputerName -ScriptBlock {
            param($appId, $policyId)
            $SMSClient = New-Object -ComObject 'Microsoft.SMS.Client'
            $AppMgmt = $SMSClient.GetClientSettings().GetApplicationManagementInterface()
            
            if ($AppMgmt) {
                $AppMgmt.InstallApplication($appId, $policyId)
                Write-Host "Installation for App ID '${appId}' successfully triggered." -ForegroundColor Green
            } else {
                Write-Error "Could not retrieve Application Management Interface. Installation not triggered."
            }
        } -ArgumentList $AppId, $PolicyId
    }
    catch {
        Write-Error "Failed to trigger installation on ${ComputerName}: ${_.Exception.Message}"
        Write-Error "Ensure SCCM client is running and permissions are sufficient."
    }
}

function Invoke-SCCMPolicyRefresh {
    [CmdletBinding()]
    param(
        [Parameter(Mandatory=$true)]
        [string]$ComputerName
    )

    Write-Host "Initiating SCCM Machine Policy Retrieval on ${ComputerName}..." -ForegroundColor Yellow

    try {
        Invoke-Command -ComputerName $ComputerName -ScriptBlock {
            $SMSClient = New-Object -ComObject 'Microsoft.SMS.Client'
            $SMSClient.TriggerSchedule("{00000000-0000-0000-0000-000000000001}") # Machine Policy Retrieval & Evaluation Cycle
            Write-Host "Machine Policy Retrieval successfully triggered." -ForegroundColor Green
        }
    }
    catch {
        Write-Error "Failed to trigger Machine Policy Retrieval on ${ComputerName}: ${_.Exception.Message}"
        Write-Error "Ensure SCCM client is running and permissions are sufficient."
    }
}

function Convert-AppNameToNormalized {
    param(
        [string]$Name
    )
    $normalizedName = $Name.ToLower().Trim()

    $normalizedName = $normalizedName -replace "(?i)^(microsoft|adobe|google|mozilla|ibm|cisco|vmware|nvidia|intel|hp|dell) "
    $normalizedName = $normalizedName -replace "(?i) (x64|x86|64-bit|32-bit|arm)$"
    $normalizedName = $normalizedName -replace "(?i) v?\d+(\.\d+){0,4}(\.\d+)?(-[a-z0-9]+)?( \d+)?( \(.*\))?$"
    $normalizedName = $normalizedName -replace "(?i) (setup|installer|client|agent|runtime|package|redistributable)$"
    $normalizedName = $normalizedName -replace "(?i) (freeware|shareware|community edition|professional|enterprise|standard|plus|viewer|reader)$"
    $normalizedName = $normalizedName -replace "[^a-z0-9 ]", ""
    $normalizedName = $normalizedName -replace " +", " "
    return $normalizedName.Trim()
}

