# EditorConfig – ADVisualizer
root = true

[*]
charset = utf-8
end_of_line = crlf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.ps1]
indent_size = 4

[*.psm1]
indent_size = 4

# Modules-Unterordner erbt alles – keine Ausnahme nötig
[Modules/*]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
